{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "mcp-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/cli.ts"],
      "port": 3000,
      "autoPort": false,
      "env": {
        "TRANSPORT": "http",
        "PORT": "3000"
      }
    },
    {
      "name": "docs-site",
      "runtimeExecutable": "docker",
      "runtimeArgs": [
        "run", "--rm", "-p", "4000:4000",
        "-v", "C:/Users/Jaime/Repos/fdic-mcp-server/docs:/srv/jekyll",
        "jekyll/jekyll:4",
        "sh", "-c", "gem install webrick && jekyll serve --force_polling --host 0.0.0.0"
      ],
      "port": 4000,
      "autoPort": false
    }
  ]
}
