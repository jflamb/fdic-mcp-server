{
  "name": "fdic-mcp-server",
  "version": "1.0.7",
  "description": "MCP server for the FDIC BankFind Suite API",
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "fdic-mcp-server": "dist/index.js"
  },
  "exports": {
    ".": "./dist/server.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "pack:check": "npm pack --dry-run",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jflamb/fdic-mcp-server.git"
  },
  "homepage": "https://github.com/jflamb/fdic-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/jflamb/fdic-mcp-server/issues"
  },
  "keywords": [
    "fdic",
    "bankfind",
    "mcp",
    "model-context-protocol",
    "banking"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.3",
    "esbuild": "^0.27.4",
    "supertest": "^7.1.4",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
