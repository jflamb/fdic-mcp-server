{
  "name": "fdic-mcp-server",
  "version": "1.1.3",
  "description": "MCP server for the FDIC BankFind Suite API",
  "mcpName": "io.github.jflamb/fdic-mcp-server",
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "fdic-mcp-server": "dist/index.js"
  },
  "exports": {
    ".": "./dist/server.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "docs:search": "pagefind --site _site",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "pack:check": "npm pack --dry-run",
    "registry:sync": "node scripts/sync-server-json.mjs",
    "fdic-schema:sync": "node scripts/sync-fdic-endpoint-metadata.mjs",
    "issues:batch": "node scripts/prepare-issue-batches.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/cli.ts",
    "deploy:local": "bash scripts/deploy-local.sh",
    "extensions:validate": "node scripts/extensions/validate-extensions.mjs",
    "extensions:build": "node scripts/extensions/build-adapters.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jflamb/fdic-mcp-server.git"
  },
  "homepage": "https://github.com/jflamb/fdic-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/jflamb/fdic-mcp-server/issues"
  },
  "keywords": [
    "fdic",
    "bankfind",
    "mcp",
    "model-context-protocol",
    "banking"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.0.0",
    "@playwright/test": "^1.58.2",
    "@semantic-release/commit-analyzer": "^12.0.0",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^13.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.3",
    "esbuild": "^0.27.4",
    "pagefind": "^1.4.0",
    "semantic-release": "^25.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4",
    "yaml": "^2.8.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
